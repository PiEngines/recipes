{
    auto_https off
}

:80 {
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    header X-XSS-Protection "1; mode=block"
    header Referrer-Policy "strict-origin-when-cross-origin"
    header Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # F3b-1: Instagram-/TikTok-Embeds brauchen drei Öffnungen — ohne sie bleibt
    # der Player stumm und die Seite fällt auf Thumbnail + Link zurück.
    #   script-src : embed.js der beiden Plattformen
    #   frame-src  : die Player-iframes, die embed.js einhängt (vorher fehlte
    #                die Direktive ganz und fiel auf default-src 'self' zurück)
    #   connect-src: die Abrufe von embed.js selbst
    # Der oEmbed-Abruf laeuft server-seitig und braucht hier nichts.
    header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.instagram.com https://www.tiktok.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.instagram.com https://www.tiktok.com; frame-src 'self' https://www.instagram.com https://www.tiktok.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net;"
    header -Server

    respond /.env 403
    respond /.git* 403
    respond /docker-compose* 403

    handle /media/* {
        root * /srv/media
        uri strip_prefix /media
        file_server
    }
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle {
        reverse_proxy frontend:3000
    }
}
